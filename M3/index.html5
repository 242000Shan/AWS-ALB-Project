<!DOCTYPE html>
<html>
<head>
<title>Star Restaurant</title>

<style>
/* Reset */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

/* Background */
body {
  background: url('https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSdoOpw_B2baUiDdN7I1SSv4L2x95jfSbao85NoknwtYNxEdcrA24yHHto&s') no-repeat center center/cover;
  height: 100vh;
  color: white;
}

/* Overlay for dark effect */
.overlay {
  background: rgba(0,0,0,0.6);
  height: 100vh;
  padding: 20px;
}

/* Navbar */
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

nav h1 {
  font-size: 28px;
  color: #9333ea;
}

nav ul {
  list-style: none;
  display: flex;
}

nav ul li {
  margin-left: 20px;
}

nav ul li a {
  text-decoration: none;
  color: white;
  font-size: 16px;
  font-weight: bold;
}

/* Hero Section */
.hero {
  text-align: center;
  margin-top: 150px;
}

.hero h2 {
  font-size: 50px;
  color: #9333ea;
}

.hero p {
  font-size: 20px;
  margin-top: 10px;
}

.hero button {
  margin-top: 20px;
  padding: 12px 25px;
  border: none;
  background: #9333ea;
  color: black;
  font-size: 18px;
  cursor: pointer;
  border-radius: 5px;
}

/* Menu Section */
.menu {
  background: white;
  color: black;
  padding: 50px;
  text-align: center;
}

.menu h2 {
  font-size: 36px;
  margin-bottom: 20px;
}

.menu-items {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.item {
  background: #f5f5f5;
  padding: 20px;
  width: 250px;
  margin: 10px;
  border-radius: 10px;
  box-shadow: 0 0 10px rgba(0,0,0,0.2);
}

/* Footer */
footer {
  background: black;
  color: white;
  text-align: center;
  padding: 10px;
}
</style>

</head>
<body>

<div class="overlay">

<!-- NAVBAR -->
<nav>
  <h1>⭐ Star Restaurant🍽️</h1>
  <ul>
    <li><a href="#">Home</a></li>
    <li><a href="#menu">Menu</a></li>
    <li><a href="#">About</a></li>
    <li><a href="#">Contact</a></li>
  </ul>
</nav>

<!-- HERO SECTION -->
<div class="hero">
  <h2>Welcome to Star Restaurant</h2>
  <p>Delicious food, great taste, and cozy place</p>
  <button>Order Now</button>
</div>

</div>

<!-- MENU SECTION -->
<div id="menu" class="menu">
  <h2>Our Special Menu</h2>
  <div class="menu-items">
    <div class="item">
      <h3>Chicken Biryani</h3>
      <p>₹250</p>
    </div>

    <div class="item">
      <h3>Paneer Butter Masala</h3>
      <p>₹180</p>
    </div>

    <div class="item">
      <h3>Masala Dosa</h3>
      <p>₹90</p>
    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <p>© 2026 Star Restaurant | All Rights Reserved</p>
</footer>

</body>
</html>
